# manage-v2.cylonix.io — environment template.
#
# Copy this file to `.env.local` (same directory) and fill in the non-secret
# values. Pass it to docker compose with:
#   docker compose --env-file .env.local up -d ...
# (or set COMPOSE_ENV_FILES=.env.local in your shell). The .env.local file
# is gitignored — do NOT commit it.
#
# Secrets do NOT live in this file anymore. They are file-based: the env
# vars below ending in _FILE are paths to files (mounted into the
# container at /etc/secrets/...). The container entrypoint reads each file
# and loads its contents into the corresponding env var without the
# _FILE suffix before rendering /etc/cylonix/{config,headscale_config}.yaml.
#
# Variable groups mirror k8s-deploy/env.sh + k8s-deploy/templates/k8s/manager/
# config.yml + cylonix-manager/docker/defaults.sh.

# ---------------------------------------------------------------------------
# Identity / branding
# ---------------------------------------------------------------------------
DEPLOYMENT=cylonix
COMPANY_NAME=EZBLOCK INC.
COMPANY_WEBSITE=https://cylonix.io
COMPANY_CONTACT_EMAIL=contact@cylonix.io

# Public URL the v2 manager is reachable at.
DOMAIN=manage-v2.cylonix.io
BASE_URL=https://manage-v2.cylonix.io

# Headscale base domain advertised in MagicDNS. MUST be a different domain
# from BASE_URL's host — headscale refuses to start otherwise (it would
# cause MagicDNS hostnames `<node>.<base_domain>` to collide with the
# control server's own hostname). Pick any subdomain you don't need to
# resolve publicly; the tailnet client resolves it via the control plane.
HEADSCALE_BASE_DOMAIN=local.cylonix.io

# ---------------------------------------------------------------------------
# Database service names + namespace (matches the k8s ConfigMap)
# ---------------------------------------------------------------------------
DATABASE_NAMESPACE=database
POSTGRES_SERVICE_NAME=postgres-service
REDIS_SERVICE_NAME=redis-service
ETCD_SERVICE_NAME=etcd-service
PROMETHEUS_SERVICE_NAME=prometheus-service
SUPERVISOR_SERVICE_NAME=supervisor-service
IPDRAWER_SERVICE_NAME=ipdrawer-service
INFLUXDB_SERVICE_NAME=influxdb-service
IPDRAWER_PORT=25577

# ---------------------------------------------------------------------------
# Postgres — username + DB name in env, password from a file.
# ---------------------------------------------------------------------------
PG_USERNAME=cylonix
PG_DB_NAME=cylonix_manager
# Read password from this file in the container (mounted from host
# /root/secrets/database/pg-password by docker-compose.yaml).
PG_PASSWORD_FILE=/etc/secrets/database/pg-password

# ---------------------------------------------------------------------------
# Sysadmin — email is the login name (no separate username). Email/name in
# env, password from file.
# ---------------------------------------------------------------------------
CYLONIX_ADMIN_EMAIL=admin@cylonix.io
CYLONIX_ADMIN_FIRST_NAME=Sys
CYLONIX_ADMIN_LAST_NAME=Admin
CYLONIX_ADMIN_PASSWORD_FILE=/etc/secrets/admin/password

# ---------------------------------------------------------------------------
# OAuth — public IDs in env, secrets from files.
# ---------------------------------------------------------------------------
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET_FILE=/etc/secrets/google/client-secret

# Apple's "client secret" is a JWT signed by the .p8 key; the manager loads
# the .p8 file at the path given in APPLE_LOGIN_CLIENT_SECRET. So this is
# already file-based by design — no _FILE suffix needed.
APPLE_LOGIN_CLIENT_ID=
APPLE_LOGIN_TEAM_ID=
APPLE_LOGIN_KEY_ID=
APPLE_LOGIN_CLIENT_SECRET=/etc/secrets/apple/private-key.p8

# Optional providers — leave empty to skip.
GITHUB_LOGIN_CLIENT_ID=
GITHUB_LOGIN_CLIENT_SECRET_FILE=
MICROSOFT_LOGIN_CLIENT_ID=
MICROSOFT_LOGIN_CLIENT_SECRET_FILE=

# ---------------------------------------------------------------------------
# Email / SMS providers
# Email service-account JSON is already file-based (the manager opens the
# JSON file directly), so SEND_EMAIL_SERVICE_ACCOUNT_FILE is NOT touched
# by the entrypoint's _FILE-loader — it stays a path.
# ---------------------------------------------------------------------------
SEND_EMAIL_PROVIDER=google
SEND_EMAIL_FROM_ADDRESS=contact@cylonix.io
SEND_EMAIL_LOCAL_NAME=Cylonix
SEND_EMAIL_SERVICE_ACCOUNT_FILE=/etc/secrets/google/service-account.json

SEND_SMS_PROVIDER=
SEND_SMS_REGION_ID=
SEND_SMS_ACCESS_KEY_ID=
SEND_SMS_ACCESS_KEY_SECRET_FILE=
SEND_SMS_REQUEST_SIGN_NAME=

# ---------------------------------------------------------------------------
# TLS / listening
# ---------------------------------------------------------------------------
CYLONIX_MANAGER_NO_TLS=true

# ---------------------------------------------------------------------------
# UI image (cylonix-manager-ui). The container runs nginx on :8001 and
# rewrites window.configs in index.html from the VITE_* env at startup
# (per cylonix-manager-ui/entrypoint.sh), so values are baked in per-deploy
# without a rebuild. VITE_BASE_URL/VITE_LOGIN_REDIRECT_BASE_URL/VITE_WS_URL
# are derived from BASE_URL above by docker-compose.yaml.
# ---------------------------------------------------------------------------
CYLONIX_UI_IMAGE=cylonix/cylonix-manager-ui:test-merge-v0.28

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
TASK_LOG_LEVEL=info
TASK_INTERVAL=60
SERVICE_SCHEME=http
ETCD_PREFIX=cylonix_manager
REDIS_PREFIX=cylonix_redis
